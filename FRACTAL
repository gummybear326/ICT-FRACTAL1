                int runMax = math.min(i + 20, bar_index)
                if i + 1 <= runMax
                    for j = i + 1 to runMax
                        if close[j] < open[j]
                            tempEnd := j
                        else
                            break
                runLength = tempEnd - i + 1
                if runLength >= 2
                    startOffset := i
                    endOffset := tempEnd
                    break
