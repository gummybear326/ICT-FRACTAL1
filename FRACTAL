detectCISDAndProjections(int c2_bar, float c2_extreme_level, bool is_bullish, int end_bar, string source_htf) =>
    series_high = usebody_for_confirmation ? math.max(open[bar_index - c2_bar], close[bar_index - c2_bar]) : c2_extreme_level
    series_low = usebody_for_confirmation ? math.min(open[bar_index - c2_bar], close[bar_index - c2_bar]) : c2_extreme_level
    series_count = 0
    series_count := 1
    for i = 1 to 20
        check_bar = c2_bar - i
        if check_bar < 0
            break
        is_bullish_candle = close[bar_index - check_bar] > open[bar_index - check_bar]
        if is_bullish
            if not is_bullish_candle
                candle_high = usebody_for_confirmation ? math.max(open[bar_index - check_bar], close[bar_index - check_bar]) : high[bar_index - check_bar]
                candle_low = usebody_for_confirmation ? math.min(open[bar_index - check_bar], close[bar_index - check_bar]) : low[bar_index - check_bar]
                series_high := math.max(series_high, candle_high)
                series_low := math.min(series_low, candle_low)
                series_count += 1
            else
                break
        else
            if is_bullish_candle
                candle_high = usebody_for_confirmation ? math.max(open[bar_index - check_bar], close[bar_index - check_bar]) : high[bar_index - check_bar]
                candle_low = usebody_for_confirmation ? math.min(open[bar_index - check_bar], close[bar_index - check_bar]) : low[bar_index - check_bar]
                series_high := math.max(series_high, candle_high)
                series_low := math.min(series_low, candle_low)
                series_count += 1
            else
                break
    series_broken = false
    break_bar = 0
    for i = 0 to (bar_index - c2_bar)
        check_bar = c2_bar + i
        if check_bar > bar_index
            break
        if is_bullish
            if close[bar_index - check_bar] > series_high
                series_broken := true
                break_bar := check_bar
                break
        else
            if close[bar_index - check_bar] < series_low
                series_broken := true
                break_bar := check_bar
                break
    if series_broken
        if show_cisd
            series_extreme = is_bullish ? series_high : series_low  // For bullish: series high, for bearish: series low
            last_series_bar = c2_bar - (series_count - 1)
            cisd_line_color = is_bullish ? bull_cisd_color : bear_cisd_color
            cisd_line = line.new(last_series_bar, series_extreme, break_bar, series_extreme, color=cisd_line_color, style=line.style_solid, width=cisd_width)
            array.unshift(cisd_lines, cisd_line)
            if show_cisd_label
                label_text = is_bullish ? bull_cisd_text : bear_cisd_text
                label.new(break_bar, series_extreme, label_text, color=color.new(color.white, 100), textcolor=cisd_line_color, style=label.style_label_left, size=cisd_label_size, text_font_family=font.family_monospace)
            invalidation_level = c2_extreme_level
            if fib_trigger_on == "Both" or fib_trigger_on == "CISD" or fib_trigger_on == "Confirmation"
                drawRiskPackage(c2_bar, break_bar, invalidation_level, series_extreme, is_bullish, end_bar)
            if is_bullish
                alerts.longCisdConfirmed := true
            else
                alerts.shortCisdConfirmed := true
            if enable_alerts and alert_cisd_confirmed and barstate.isconfirmed
                CAL.customAlert(alertFormat, (is_bullish ? "CISD C2 Long" : "CISD C2 Short") + " confirmed on candle close on " + syminfo.ticker + " (" + source_htf + ")")
        if false and show_projections
            series_range = series_high - series_low
            if series_range > 0
                break_price = is_bullish ? series_high : series_low
                levels = str.split(projection_levels, ",")
                for i = 0 to array.size(levels) - 1
                    level_str = str.trim(array.get(levels, i))
                    if level_str != ""
                        level = str.tonumber(level_str)
                        if not na(level)
                            proj_price = is_bullish ? break_price + (series_range * level) : break_price - (series_range * level)
                            line_start = fib_x1_from_pivot ? c2_bar : break_bar
                            line_end = extend_latest_projections ? bar_index : end_bar
                            fib_color = is_bullish ? bull_levels_color : bear_levels_color
                            label_x = fib_label_side == "Right" ? line_end : line_start
                            label_style = fib_label_side == "Right" ? label.style_label_right : label.style_label_left
                            proj_line = line.new(line_start, proj_price, line_end, proj_price, color=fib_color, style=toLineStyle(fib_line_style), width=fib_line_width)
                            proj_label = label.new(label_x, proj_price, str.tostring(level), color=color.new(color.white, 100), textcolor=fib_color, style=label_style, size=projection_label_size, text_font_family=font.family_monospace)
                            array.unshift(projection_lines, proj_line)
                            array.unshift(projection_labels, proj_label)
