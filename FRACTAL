updateBreakerSetups() =>
    if breaker_setups.size() > 0
        for idx = breaker_setups.size() - 1 to 0
            BreakerSetup setup = breaker_setups.get(idx)
            if not setup.isInvalidated
                bool invalidated = setup.dir == "BULL" ? low < setup.invalidationPrice : high > setup.invalidationPrice
