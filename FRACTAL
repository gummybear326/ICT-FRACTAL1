breakerFindBullishFVG(float breakerTop, float breakerBottom, int breakerStartBar) =>
    float fvgTop = na
    float fvgBottom = na
    int fvgLeft = na
    int fvgRight = na
    int limit = math.min(bar_index - breakerStartBar, 100)
    if limit >= 0
        for i = 0 to limit
            if low[i] > high[i + 2]
                top = low[i]
                bottom = high[i + 2]
                atrVal = ta.atr(14)[i]
                if breaker_enable_fvg_atr_filter and (top - bottom) < (atrVal * breaker_fvg_atr_mult)
                    continue
                overlaps = math.max(bottom, breakerBottom) < math.min(top, breakerTop)
                if overlaps
                    bool unmitigated = true
                    for j = 0 to i
                        if low[j] < bottom
                            unmitigated := false
                            break
                    if unmitigated
                        fvgTop := top
                        fvgBottom := bottom
                        fvgLeft := bar_index - i - 1
                        fvgRight := bar_index - i
                        break
    [fvgTop, fvgBottom, fvgLeft, fvgRight]
