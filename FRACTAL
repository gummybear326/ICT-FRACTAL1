nextHTF(string baseHtf) =>
    int sec = timeframe.in_seconds(baseHtf)
    if sec <= timeframe.in_seconds("15")
        "30"
    else if sec <= timeframe.in_seconds("30")
        "60"
    else if sec <= timeframe.in_seconds("60")
        "240"
    else if sec <= timeframe.in_seconds("240")
        "1D"
    else if sec <= timeframe.in_seconds("1D")
        "1W"
    else if sec <= timeframe.in_seconds("1W")
        "1M"
    else
        "3M"
