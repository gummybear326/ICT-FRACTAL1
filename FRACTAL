markMinimalLevelTaken(bool visible, float price, bool isHighLevel, bool canCheck, int takenBar) =>
    int outTakenBar = takenBar
    if visible and canCheck and na(outTakenBar) and not na(price)
        bool isTaken = isHighLevel ? high >= price : low <= price
        if isTaken
            outTakenBar := bar_index
    outTakenBar
updateMinimalLevel(bool visible, float price, string levelText, color col, int startBar, int stopBar, line ln, label lb) =>
    line outLine = ln
    label outLabel = lb
    if visible and not na(price)
        int x1Base = na(startBar) ? math.max(bar_index - levels_left_bars, 0) : math.max(startBar, bar_index - 5000)
        int x2 = na(stopBar) ? bar_index + levels_extend_bars : stopBar
        int x1 = na(stopBar) ? x1Base : math.min(x1Base, x2)
        if na(outLine)
            outLine := line.new(x1, price, x2, price, color=col, style=toLineStyle(levels_line_style), width=levels_line_width, xloc=xloc.bar_index)
        else
            line.set_xy1(outLine, x1, price)
            line.set_xy2(outLine, x2, price)
            line.set_color(outLine, col)
            line.set_style(outLine, toLineStyle(levels_line_style))
            line.set_width(outLine, levels_line_width)
        if levels_show_labels
            if na(outLabel)
                outLabel := label.new(x2, price, levelText, color=color.new(color.white, 100), textcolor=col, style=label.style_label_left, size=levels_label_size, text_font_family=font.family_monospace)
            else
                label.set_xy(outLabel, x2, price)
                label.set_text(outLabel, levelText)
                label.set_textcolor(outLabel, col)
                label.set_size(outLabel, levels_label_size)
        else if not na(outLabel)
            label.delete(outLabel)
            outLabel := na
    else
        if not na(outLine)
            line.delete(outLine)
            outLine := na
        if not na(outLabel)
            label.delete(outLabel)
            outLabel := na
    [outLine, outLabel]
clearRiskPackage() =>
    while array.size(projection_lines) > 0
        line.delete(array.pop(projection_lines))
    while array.size(projection_labels) > 0
        label.delete(array.pop(projection_labels))
    while array.size(invalidation_lines) > 0
        line.delete(array.pop(invalidation_lines))
    while array.size(invalidation_labels) > 0
        label.delete(array.pop(invalidation_labels))
    while array.size(invalidation_boxes) > 0
        box.delete(array.pop(invalidation_boxes))
    array.clear(active_setup_origin_bars)
    array.clear(active_setup_trigger_bars)
    array.clear(active_setup_trigger_levels)
    array.clear(active_setup_directions)
    array.clear(active_setup_live_flags)
drawRiskPackage(int origin_bar, int trigger_bar, float invalidation_level, float trigger_level, bool is_bullish, int end_bar) =>
    if not keep_both_fibs
        clearRiskPackage()
    int line_end = trigger_bar + projection_length_bars
    line_end := math.min(line_end, bar_index + 500)
    line_end := math.max(line_end, trigger_bar + 1)
    top_level = math.max(invalidation_level, trigger_level)
    bottom_level = math.min(invalidation_level, trigger_level)
    invalidation_line = line.new(trigger_bar, invalidation_level, line_end, invalidation_level, color=invalidation_label_color, style=toLineStyle(invalidation_label_style), width=1)
    invalidation_box = box.new(trigger_bar, top_level, line_end, bottom_level, bgcolor=color.new(invalidation_label_color, 92), border_color=color.new(invalidation_label_color, 100), xloc=xloc.bar_index)
    invalidation_label = label.new(line_end, invalidation_level, invalidation_label_text, color=color.new(color.white, 100), textcolor=invalidation_label_color, style=label.style_label_left, size=projection_label_size, text_font_family=font.family_monospace)
    array.unshift(invalidation_lines, invalidation_line)
    array.unshift(invalidation_boxes, invalidation_box)
    array.unshift(invalidation_labels, invalidation_label)
    array.unshift(active_setup_origin_bars, origin_bar)
    array.unshift(active_setup_trigger_bars, trigger_bar)
    array.unshift(active_setup_trigger_levels, trigger_level)
    array.unshift(active_setup_directions, is_bullish)
    array.unshift(active_setup_live_flags, false)
    if show_projections
