use_actual_day_change = input.bool(false, "Use Actual Day Change for Daily HTF", group=GRP_GENERAL, tooltip="When enabled, uses dayofmonth() comparison instead of ta.change() for daily timeframe detection.")
fractal_bias = input.string("None", "Manual T-Spot Bias", options=["None", "Bullish", "Bearish"], group=GRP_GENERAL)
